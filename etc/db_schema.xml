<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="dlabsit_xmlfeed_feed" resource="default" engine="innodb" comment="Dlabsit XML Feed — feed registry">
        <column xsi:type="int" name="feed_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Feed ID"/>
        <column xsi:type="varchar" name="slug" nullable="false" length="64" comment="URL slug (e.g. google-adult)"/>
        <column xsi:type="varchar" name="channel_code" nullable="false" length="32" comment="Writer code (google, skroutz, facebook, ...)"/>
        <column xsi:type="smallint" name="store_id" padding="5" unsigned="true" nullable="false" default="0" comment="Store ID (0 = admin / default)"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true" comment="Enabled"/>
        <column xsi:type="varchar" name="name" nullable="false" length="128" comment="Display name"/>
        <column xsi:type="varchar" name="filename" nullable="false" length="128" comment="Output filename under pub/media/xmlfeed/"/>
        <column xsi:type="varchar" name="filter_mode" nullable="false" length="16" default="all" comment="all | include | exclude"/>
        <column xsi:type="text" name="category_ids" nullable="true" comment="Comma-separated category IDs for include/exclude"/>
        <column xsi:type="text" name="channel_settings" nullable="true" comment="JSON with channel-specific overrides"/>
        <column xsi:type="smallint" name="sort_order" padding="5" unsigned="true" nullable="false" default="0" comment="Sort order"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="feed_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="DLABSIT_XMLFEED_FEED_SLUG_STORE_ID">
            <column name="slug"/>
            <column name="store_id"/>
        </constraint>
        <index referenceId="DLABSIT_XMLFEED_FEED_CHANNEL_CODE_IS_ACTIVE" indexType="btree">
            <column name="channel_code"/>
            <column name="is_active"/>
        </index>
        <index referenceId="DLABSIT_XMLFEED_FEED_STORE_ID" indexType="btree">
            <column name="store_id"/>
        </index>
    </table>
</schema>
